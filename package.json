{
	"name": "nicookie",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"check": "pnpm format:check && pnpm typecheck && pnpm lint",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"format:diff": "oxfmt --write . && git --no-pager diff",
		"lint": "oxlint --type-aware --tsconfig tsconfig.lint.json --config .oxlintrc.json .",
		"lint:fix": "oxlint --type-aware --tsconfig tsconfig.lint.json --config .oxlintrc.json --fix . && pnpm format",
		"audit": "pnpm audit",
		"test": "vitest run --coverage",
		"test:bun": "bun test packages/core/tests-bun",
		"test:watch": "vitest",
		"typecheck": "pnpm -r typecheck"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@typescript/native-preview": "7.0.0-dev.20260517.1",
		"@vitest/coverage-v8": "^4.1.6",
		"oxfmt": "^0.50.0",
		"oxlint": "^1.65.0",
		"oxlint-tsgolint": "^0.22.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"packageManager": "pnpm@10.25.0"
}
